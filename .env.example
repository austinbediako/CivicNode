# ============================================================
# CivicNode Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Database ---
# MongoDB connection string (local Docker: mongodb://localhost:27017/civicnode)
MONGODB_URI=mongodb://localhost:27017/civicnode

# Redis connection string (local Docker: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=

# --- AI ---
# Anthropic API key for Claude synthesis (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Claude model to use for proposal synthesis
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Blockchain (Sui) ---
# Sui RPC URL (testnet: https://fullnode.testnet.sui.io:443)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Deployed Sui package ID (set after deploying the contract)
SUI_PACKAGE_ID=

# Private key for the backend executor account (bech32 suiprivkey1... or hex)
SUI_EXECUTOR_PRIVATE_KEY=

# --- Backend Server ---
# Port for the Express backend server
PORT=4000

# CORS origin for the frontend (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development

# --- Frontend (prefixed with NEXT_PUBLIC_ for client-side access) ---
# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Sui network identifier
NEXT_PUBLIC_SUI_NETWORK=testnet

# Deployed Sui package ID (same as SUI_PACKAGE_ID, exposed to client)
NEXT_PUBLIC_SUI_PACKAGE_ID=

# --- Enoki (zkLogin) ---
# Public Enoki API key from https://enoki.mystenlabs.com
NEXT_PUBLIC_ENOKI_API_KEY=

# Google OAuth Client ID for zkLogin
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Twitch OAuth Client ID for zkLogin (optional)
NEXT_PUBLIC_TWITCH_CLIENT_ID=

# --- Rate Limiting ---
# Max AI synthesis calls per community per day
RATE_LIMIT_AI_PER_DAY=10
