# ============================================================
# CivicNode Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Database ---
# MongoDB connection string (local Docker: mongodb://localhost:27017/civicnode)
MONGODB_URI=mongodb://localhost:27017/civicnode

# Redis connection string (local Docker: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# Secret key for signing JWT tokens (generate with: openssl rand -hex 32)
JWT_SECRET=

# --- AI ---
# Anthropic API key for Claude synthesis (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Claude model to use for proposal synthesis
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Blockchain (Aptos) ---
# Aptos node URL (devnet: https://fullnode.devnet.aptoslabs.com/v1)
APTOS_NODE_URL=https://fullnode.devnet.aptoslabs.com/v1

# Aptos faucet URL for devnet funding
APTOS_FAUCET_URL=https://faucet.devnet.aptoslabs.com

# Deployed Move module address (set after deploying the contract)
APTOS_MODULE_ADDRESS=

# Private key for the backend executor account (hex, no 0x prefix)
APTOS_EXECUTOR_PRIVATE_KEY=

# --- Backend Server ---
# Port for the Express backend server
PORT=4000

# CORS origin for the frontend (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development

# --- Frontend (prefixed with NEXT_PUBLIC_ for client-side access) ---
# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4000

# Aptos network identifier
NEXT_PUBLIC_APTOS_NETWORK=devnet

# Deployed module address (same as APTOS_MODULE_ADDRESS, exposed to client)
NEXT_PUBLIC_MODULE_ADDRESS=

# --- Rate Limiting ---
# Max AI synthesis calls per community per day
RATE_LIMIT_AI_PER_DAY=10
