# ============================================================
# CivicNode Backend — Environment Variables
# Copy this to .env and fill in real values before running.
# ============================================================

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/civicnode
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Anthropic AI ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Aptos Blockchain ---
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1
APTOS_MODULE_ADDRESS=0x1
APTOS_EXECUTOR_PRIVATE_KEY=0x...

# --- Server ---
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# --- Rate Limiting ---
RATE_LIMIT_AI_PER_DAY=10
